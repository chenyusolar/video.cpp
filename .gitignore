# =============================================================================
# video.cpp .gitignore
# Excludes build artifacts, intermediate files, and downloaded models
# =============================================================================

# -----------------------------------------------------------------------------
# Build Artifacts (Rust)
# -----------------------------------------------------------------------------
core/target/
Cargo.lock

# -----------------------------------------------------------------------------
# Build Artifacts (Go)
# -----------------------------------------------------------------------------
**/*.a
**/*.o
**/*.so
**/*.dylib
**/*.dll
**/*.exe
**/*.obj
**/*.pdb

# Binaries
bin/
dist/
build/

# -----------------------------------------------------------------------------
# IDE and Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.user
*.suo
*.sln.docstates

# -----------------------------------------------------------------------------
# Environment and Config (keep .env.example)
# -----------------------------------------------------------------------------
!.env
!.env.local
!.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Downloaded Models
# -----------------------------------------------------------------------------
models/
*.gguf
*.safetensors
*.pt
*.pth
*.ckpt
*.onnx

# Model caches
model_cache/
.huggingface/

# -----------------------------------------------------------------------------
# Generated Output
# -----------------------------------------------------------------------------
*.mp4
*.webm
*.avi
*.mov
*.mkv
*.gif
*.rgb
*.raw
output/
outputs/
results/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
video_core*.log

# -----------------------------------------------------------------------------
# Test Coverage
# -----------------------------------------------------------------------------
coverage/
*.prof
*.gcda
*.gcno

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.cache
*.swp
*.swo

# -----------------------------------------------------------------------------
# Rust-specific
# -----------------------------------------------------------------------------
**/target/
Cargo.lock

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# C/C++
# -----------------------------------------------------------------------------
*.o
*.a
*.lib
*.obj
*.pdb
*.idb
*.pch
*.ilk
*.exp

# -----------------------------------------------------------------------------
# CUDA
# -----------------------------------------------------------------------------
*.cu
*.cuh
*.ptx
*.fatbin
nvcc_log/

