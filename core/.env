# video.cpp environment configuration

# Model configuration - use absolute path
VIDEO_MODEL_PATH=E:\vllm-project\video.cpp\models\ltx-2.3-22b-dev-Q4_K_M.gguf
VIDEO_MODEL_TYPE=ltx-video

# Backend selection: auto, cpu, cuda, vulkan
VIDEO_BACKEND=cpu
VIDEO_DEVICE_ID=0

# GPU configuration
VIDEO_USE_GPU=true
VIDEO_VRAM_SIZE_MB=24576

# Memory management
VIDEO_AVAILABLE_MEMORY_MB=32768
VIDEO_OFFLOAD_THRESHOLD_MB=16000
VIDEO_USE_OFFLOAD=false

# Generation defaults
VIDEO_STEPS=30
VIDEO_GUIDANCE_SCALE=7.5
VIDEO_SAMPLER=euler
VIDEO_FPS=24

# Quantization: auto, none, int8, nf4, fp8
VIDEO_QUANTIZATION=auto
VIDEO_QUANT_BLOCK_SIZE=32

# Performance
VIDEO_NUM_THREADS=8
VIDEO_USE_FLASH_ATTENTION=true

# Logging
RUST_LOG=info
